{
  "compilerOptions": {
    "target": "esnext",
    "jsx": "react",
    "sourceMap": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "neo4j-arc/common": ["./common/index.ts"]
    }
  },
  "exclude": ["**/*.test.ts", "**/*.test.tsx"]
}
